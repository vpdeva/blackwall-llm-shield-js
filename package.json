{
  "name": "@vpdeva/blackwall-llm-shield-js",
  "version": "0.7.0",
  "description": "Security middleware for Node.js and Next.js LLM apps. Blocks prompt injection, masks PII, inspects outputs, and gates agent tools.",
  "license": "Apache-2.0",
  "author": "Vish <hello@vish.au> (https://vish.au)",
  "type": "commonjs",
  "main": "src/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./src/index.js"
    },
    "./integrations": {
      "types": "./integrations.d.ts",
      "default": "./src/integrations.js"
    },
    "./providers": {
      "types": "./providers.d.ts",
      "default": "./src/providers.js"
    },
    "./edge": {
      "types": "./edge.d.ts",
      "default": "./src/edge.js"
    },
    "./semantic": {
      "types": "./semantic.d.ts",
      "default": "./src/semantic.js"
    }
  },
  "bin": {
    "blackwall-scorecard": "src/scorecard.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:check": "npm test",
    "release:pack": "npm pack",
    "release:publish": "npm publish --access public --provenance"
  },
  "files": [
    "src",
    "edge.d.ts",
    "index.d.ts",
    "integrations.d.ts",
    "providers.d.ts",
    "semantic.d.ts",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vpdeva/blackwall-llm-shield-js.git"
  },
  "homepage": "https://github.com/vpdeva/blackwall-llm-shield-js",
  "bugs": {
    "url": "https://github.com/vpdeva/blackwall-llm-shield-js/issues"
  },
  "funding": {
    "type": "Buy Vish a coffee",
    "url": "https://buymeacoffee.com/vishdevarae"
  },
  "keywords": [
    "llm",
    "llm-security",
    "llm-guardrails",
    "prompt-injection",
    "jailbreak-detection",
    "ai-security",
    "pii-masking",
    "pii",
    "rag-security",
    "retrieval-sanitizer",
    "output-firewall",
    "owasp-llm",
    "langchain",
    "llamaindex",
    "openai",
    "anthropic",
    "gemini",
    "enterprise",
    "nextjs",
    "node",
    "edge",
    "ai-middleware",
    "agentic-ai",
    "ai-safety",
    "ai-audit",
    "shadow-mode",
    "streaming-firewall"
  ],
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6"
  }
}
